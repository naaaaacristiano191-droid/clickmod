name: Bootstrap and Build ClickMod

on:
  workflow_dispatch:
  push:
    branches: [ main, master ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Java 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Create README.md
        run: |
          mkdir -p "."
          echo "<BASE64 CONTENT>" | base64 -d > README.md

      - name: Create src/main/java/com/example/clickmod/mixin/MinecraftMixin.java
        run: |
          mkdir -p "src/main/java/com/example/clickmod/mixin"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/java/com/example/clickmod/mixin/MinecraftMixin.java"

      - name: Create src/main/resources/META-INF/accesstransformer.cfg
        run: |
          mkdir -p "src/main/resources/META-INF"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/META-INF/accesstransformer.cfg"

      - name: Create src/main/resources/META-INF/mods.toml
        run: |
          mkdir -p "src/main/resources/META-INF"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/META-INF/mods.toml"

      - name: Create src/main/resources/assets/clickmod/sounds/click.ogg
        run: |
          mkdir -p "src/main/resources/assets/clickmod/sounds"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/assets/clickmod/sounds/click.ogg"

      - name: Create src/main/resources/assets/clickmod/sounds.json
        run: |
          mkdir -p "src/main/resources/assets/clickmod"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/assets/clickmod/sounds.json"

      - name: Create src/main/resources/clickmod.mixins.json
        run: |
          mkdir -p "src/main/resources"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/clickmod.mixins.json"

      - name: Create src/main/resources/pack.mcmeta
        run: |
          mkdir -p "src/main/resources"
          echo "<BASE64 CONTENT>" | base64 -d > "src/main/resources/pack.mcmeta"

      - name: Download Gradle wrapper JAR
        run: |
          mkdir -p gradle/wrapper
          curl -L "https://github.com/gradle/gradle/raw/v8.1.1/gradle/wrapper/gradle-wrapper.jar" -o gradle/wrapper/gradle-wrapper.jar

      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: gradle-${{ hashFiles('**/*.gradle*', '**/gradle-wrapper.properties') }}

      - name: Build
        run: |
          chmod +x gradlew
          ./gradlew build --no-daemon
        env:
          GRADLE_OPTS: "-Xmx3G"

      - name: Upload JAR
        uses: actions/upload-artifact@v4
        with:
          name: clickmod-1.0.0
          path: build/libs/clickmod-1.0.0.jar
          retention-days: 30
